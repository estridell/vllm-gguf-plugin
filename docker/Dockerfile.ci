# Default stable vLLM base image tag. Override VLLM_BASE_TAG at build time when needed.
ARG VLLM_BASE_IMAGE=vllm/vllm-openai
ARG VLLM_BASE_TAG=latest
FROM ${VLLM_BASE_IMAGE}:${VLLM_BASE_TAG}

ARG APP_DIR=/workspace/vllm-gguf-plugin
WORKDIR ${APP_DIR}
COPY . .

RUN uv pip install --system -e ".[dev]"

RUN ln -sf /usr/bin/python3 /usr/bin/python

ENTRYPOINT []
